# Base de datos (PostgreSQL)
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/conectapp"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-string-aleatorio-seguro"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudinary (imágenes) (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# MercadoPago (https://www.mercadopago.com.ar/developers)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""
# Opcional: secreto para verificar firma de webhooks de MercadoPago
MERCADOPAGO_WEBHOOK_SECRET=""

# Email transaccional con Resend (https://resend.com)
RESEND_API_KEY=""
# Dirección del remitente (debe ser un dominio verificado en Resend)
# Durante desarrollo podés usar: "onboarding@resend.dev"
RESEND_FROM="Conect App <noreply@tudominio.com>"

# Panel de administración — emails separados por coma
# Si está vacío, cualquier usuario autenticado puede acceder a /admin
ADMIN_EMAILS="tu@email.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"
