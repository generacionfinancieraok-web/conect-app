generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTENTICACIÓN ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  bio           String?
  rating        Float     @default(0)
  ratingCount   Int       @default(0)
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Reputación del vendedor
  completedSales       Int   @default(0)   // transacciones concretadas como vendedor
  totalAcceptedOffers  Int   @default(0)   // ofertas aceptadas como vendedor
  concretionRate       Float @default(0)   // completedSales / totalAcceptedOffers
  avgResponseMinutes   Int   @default(0)   // minutos promedio para responder oferta

  // Reputación del comprador
  offersRejected       Int   @default(0)   // rechazos en últimos 30 días (ponderado)
  offersTotal          Int   @default(0)   // total de ofertas enviadas
  offerRejectionRatio  Float @default(0)   // offersRejected / offersTotal
  buyerLevel           Int   @default(0)   // 0=verde 1=amarillo 2=naranja 3=rojo 4=suspendido
  buyerLevelSince      DateTime?           // cuándo entró al nivel actual
  suspendedUntil       DateTime?           // si está suspendido

  // Compras concretadas
  completedPurchases   Int   @default(0)

  accounts         Account[]
  sessions         Session[]
  listings         Listing[]
  sentMessages     Message[]       @relation("SentMessages")
  conversations    Conversation[]  @relation("ConversationParticipants")
  reviews          Review[]        @relation("ReviewsReceived")
  reviewsGiven     Review[]        @relation("ReviewsGiven")
  payments         Payment[]
  favorites        Favorite[]
  offersBuyer      Offer[]         @relation("OfferBuyer")
  offersSeller     Offer[]         @relation("OfferSeller")
  reportsMade      Report[]        @relation("ReportsMade")
  reportsReceived  Report[]        @relation("ReportsReceived")
  followers        Follow[]        @relation("Following")
  following        Follow[]        @relation("Follower")
  pushTokens        PushToken[]
  notifications     Notification[]
  passwordResetToken PasswordResetToken?
  blockedUsers      BlockedUser[]   @relation("BlockerUser")
  blockedBy         BlockedUser[]   @relation("BlockedUser")
  offerBlocks       OfferBlock[]    @relation("OfferBlockBuyer")
  discoverDismisses DiscoverDismiss[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── PUBLICACIONES ───────────────────────────────────────────────────────────

enum ListingType {
  ITEM_WITH_PRICE   // Tipo 1: artículo con precio (Consultar + Hacer Oferta)
  ITEM_NO_PRICE     // Tipo 2: artículo sin precio (solo Hacer Oferta)
  SERVICE           // Tipo 3: servicio (solo Enviar Mensaje)
}

enum ServiceUnit {
  HOURLY      // por hora
  PROJECT     // por proyecto
  VISIT       // por visita
  SESSION     // por sesión
  FIXED       // precio fijo
}

enum ServiceModality {
  IN_PERSON
  REMOTE
  BOTH
}

enum ListingStatus {
  ACTIVE
  SOLD
  PAUSED
  DELETED
}

enum Condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String?
  listings Listing[]

  @@map("categories")
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  description String        @db.Text
  price       Float         @default(0)
  currency    String        @default("ARS")
  condition   Condition     @default(GOOD)
  status      ListingStatus @default(ACTIVE)

  // Tipo de publicación
  listingType ListingType   @default(ITEM_WITH_PRICE)

  // Tipo 1: precio mínimo aceptado para ofertas
  minPrice    Float?

  // Tipo 3: campos de servicio
  serviceUnit     ServiceUnit?
  serviceModality ServiceModality?
  serviceCoverage String?   // zona de cobertura

  city        String
  province    String
  address     String?
  latitude    Float?
  longitude   Float?

  views       Int           @default(0)
  saves       Int           @default(0)
  videoUrl    String?
  promoted    Boolean       @default(false)
  promotedAt  DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userId      String
  categoryId  String

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id])
  images        ListingImage[]
  conversations Conversation[]
  payments      Payment[]
  favorites         Favorite[]
  offers            Offer[]
  reports           Report[]       @relation("ListingReports")
  promotion         Promotion?
  offerBlocks       OfferBlock[]
  discoverDismisses DiscoverDismiss[]

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([promoted])
  @@index([latitude, longitude])
  @@index([listingType])
  @@map("listings")
}

model ListingImage {
  id         String  @id @default(cuid())
  url        String
  publicId   String
  order      Int     @default(0)
  listingId  String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

// ─── FAVORITOS ───────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@map("favorites")
}

// ─── OFERTAS ─────────────────────────────────────────────────────────────────

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  EXPIRED
}

model Offer {
  id        String      @id @default(cuid())
  amount    Float
  message   String?     @db.Text
  status    OfferStatus @default(PENDING)
  buyerId   String
  sellerId  String
  listingId String
  expiresAt DateTime?   // 24hs desde creación
  retryCount Int        @default(0) // número de reintento (0=primera, 1=segunda, 2=tercera)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  buyer   User    @relation("OfferBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller  User    @relation("OfferSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([expiresAt])
  @@map("offers")
}

// Bloqueo comprador-publicación (para reintentos y bloqueos permanentes)
model OfferBlock {
  id          String   @id @default(cuid())
  buyerId     String
  listingId   String
  retryCount  Int      @default(0)  // cuántos rechazos tuvo en esta publicación
  ignoredCount Int     @default(0)  // cuántas veces fue ignorado en esta publicación
  blockedUntil DateTime?            // bloqueado hasta esta fecha (null=no bloqueado)
  permanent   Boolean  @default(false) // bloqueo permanente (4to rechazo)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buyer   User    @relation("OfferBlockBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([buyerId, listingId])
  @@index([buyerId])
  @@index([listingId])
  @@map("offer_blocks")
}

// ─── MENSAJERÍA ──────────────────────────────────────────────────────────────

enum ConversationStatus {
  PENDING_REQUEST   // Tipo 3: esperando aceptación del receptor
  ACTIVE            // chat habilitado
  REJECTED          // receptor rechazó la solicitud
  BLOCKED           // uno bloqueó al otro
}

model Conversation {
  id        String             @id @default(cuid())
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  status    ConversationStatus @default(ACTIVE)

  // Para solicitudes de mensaje (Tipo 3)
  requesterId   String?  // quien inició la conversación
  requestMessage String? @db.Text  // primer mensaje de solicitud

  listingId String
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  participants User[]    @relation("ConversationParticipants")
  messages     Message[]

  @@index([status])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  body           String       @db.Text
  read           Boolean      @default(false)
  messageType    String       @default("text") // text | image | offer | proposal | system
  metadata       String?      @db.Text  // JSON: propuesta formal, contraoferta, etc.
  createdAt      DateTime     @default(now())

  senderId       String
  conversationId String

  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// ─── BLOQUEO DE USUARIOS ─────────────────────────────────────────────────────

model BlockedUser {
  id          String   @id @default(cuid())
  blockerId   String
  blockedId   String
  createdAt   DateTime @default(now())

  blocker User @relation("BlockerUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@map("blocked_users")
}

// ─── PAGOS ───────────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model Payment {
  id              String        @id @default(cuid())
  amount          Float
  currency        String        @default("ARS")
  status          PaymentStatus @default(PENDING)
  mpPaymentId     String?       @unique
  mpPreferenceId  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  userId    String
  listingId String

  user    User    @relation(fields: [userId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])

  @@map("payments")
}

// ─── RESEÑAS ─────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?  @db.Text
  listingId  String?
  createdAt  DateTime @default(now())

  reviewedId String
  reviewerId String

  reviewed User    @relation("ReviewsReceived", fields: [reviewedId], references: [id], onDelete: Cascade)
  reviewer User    @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, reviewedId])
  @@map("reviews")
}

// ─── REPORTES ────────────────────────────────────────────────────────────────

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}

model Report {
  id             String       @id @default(cuid())
  reason         String
  details        String?      @db.Text
  status         ReportStatus @default(PENDING)
  reporterId     String
  listingId      String?
  userId         String?
  conversationId String?      // reporte dentro de un chat
  evidence       String?      @db.Text  // JSON: historial capturado
  createdAt      DateTime     @default(now())

  reporter User     @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  listing  Listing? @relation("ListingReports", fields: [listingId], references: [id], onDelete: SetNull)
  user     User?    @relation("ReportsReceived", fields: [userId], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([status])
  @@map("reports")
}

// ─── SEGUIMIENTO ─────────────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

// ─── NOTIFICACIONES PUSH ─────────────────────────────────────────────────────

model PushToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

enum NotificationType {
  MESSAGE
  MESSAGE_REQUEST           // solicitud de chat (Tipo 3)
  MESSAGE_REQUEST_ACCEPTED  // solicitud aceptada
  MESSAGE_REQUEST_REJECTED  // solicitud rechazada
  OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
  OFFER_COUNTERED
  OFFER_EXPIRED             // oferta vencida sin respuesta
  OFFER_EXPIRING_SOON       // oferta por vencer en 2hs
  SERVICE_CONTRACTED        // servicio confirmado
  NEW_FOLLOWER
  REVIEW
  LISTING_SOLD
  PRICE_DROP
  PAYMENT
  BUYER_LEVEL_WARNING       // advertencia de nivel comprador
  SIMILAR_LISTINGS          // publicaciones similares post-rechazo
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  data      String?          // JSON extra data
  read      Boolean          @default(false)
  userId    String
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

// ─── PASSWORD RESET ──────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expires   DateTime
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── DESCUBRIR ───────────────────────────────────────────────────────────────

model DiscoverDismiss {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @re