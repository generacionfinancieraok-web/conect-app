# ══════════════════════════════════════════════════════════════
#  VARIABLES DE ENTORNO — PRODUCCIÓN (Railway)
#  Copiar esto al panel de Railway → Variables
# ══════════════════════════════════════════════════════════════

# ─── BASE DE DATOS ────────────────────────────────────────────
# Railway te la genera automáticamente al agregar PostgreSQL
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ─── NEXTAUTH ─────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=GENERAR_CON_OPENSSL
NEXTAUTH_URL=https://TU_DOMINIO.railway.app
JWT_SECRET=GENERAR_CON_OPENSSL_DISTINTO

# ─── APP URL ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://TU_DOMINIO.railway.app
NEXT_PUBLIC_SOCKET_URL=https://TU_DOMINIO.railway.app

# ─── CLOUDINARY ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ─── MERCADO PAGO ─────────────────────────────────────────────
# Producción: APP_USR-... (sin TEST-)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-tu_token_produccion

# ─── SERVIDOR ─────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
